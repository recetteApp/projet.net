@using Microsoft.AspNetCore.Components.Authorization

<div class="top-row ps-3 navbar navbar-dark">
    <div class="container-fluid">
        <a class="navbar-brand" href="">🍽️ RecetteApp</a>
    </div>
</div>

<input type="checkbox" title="Navigation menu" class="navbar-toggler" />

<div class="nav-scrollable" onclick="document.querySelector('.navbar-toggler').click()">
    <nav class="nav flex-column">
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="" Match="NavLinkMatch.All">
                <span class="bi bi-house-door-fill-nav-menu" aria-hidden="true"></span> Tableau de bord
            </NavLink>
        </div>

        <div class="nav-item px-3">
            <NavLink class="nav-link" href="recettes">
                <span class="bi bi-book-fill" aria-hidden="true"></span> Recettes
            </NavLink>
        </div>

        <div class="nav-item px-3">
            <NavLink class="nav-link" href="ingredients">
                <span class="bi bi-basket-fill" aria-hidden="true"></span> Ingrédients
            </NavLink>
        </div>

        <hr class="nav-divider" />

        <AuthorizeView>
            <Authorized>
                <div class="nav-item px-3">
                    <span class="nav-link text-light small">
                        👤 @context.User.Identity?.Name
                    </span>
                </div>
                <div class="nav-item px-3">
                    <NavLink class="nav-link text-danger" href="logout">
                        <span class="bi bi-box-arrow-right" aria-hidden="true"></span> Déconnexion
                    </NavLink>
                </div>
            </Authorized>
            <NotAuthorized>
                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="login">
                        <span class="bi bi-lock-fill" aria-hidden="true"></span> Connexion
                    </NavLink>
                </div>
                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="register">
                        <span class="bi bi-person-plus-fill" aria-hidden="true"></span> Inscription
                    </NavLink>
                </div>
            </NotAuthorized>
        </AuthorizeView>
    </nav>
</div>
