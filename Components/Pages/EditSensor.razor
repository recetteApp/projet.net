@* EditRecette – édition d'une recette existante + gestion des ingrédients *@
@page "/recettes/{Id:int}"
@using RecetteApp.Models
@using RecetteApp.Services
@inject IRecetteService   Svc
@inject NavigationManager Nav
@rendermode InteractiveServer

<PageTitle>@(_recette?.Titre ?? "Recette") – RecetteApp</PageTitle>

@if (_recette is null)
{
    <div class="loading">Chargement...</div>
}
else
{
    <div class="page-header">
        <h1>✏️ @_recette.Titre</h1>
        <button class="btn btn-secondary" @onclick='() => Nav.NavigateTo("/recettes")'>← Retour</button>
    </div>

    <div class="card form-card">
        <h2>Informations générales</h2>

        @if (!string.IsNullOrEmpty(_message))
        {
            <div class="alert @(_success ? "alert-success" : "alert-danger")">@_message</div>
        }

        <div class="form-grid">
            <div class="form-group">
                <label>Titre *</label>
                <input class="form-input" @bind="_recette.Titre" />
            </div>
            <div class="form-group">
                <label>Nombre de personnes</label>
                <input class="form-input" type="number" min="1" max="100" @bind="_recette.NbPersonnes" />
            </div>
            <div class="form-group">
                <label>Catégorie *</label>
                <select class="form-select" @bind="_recette.CategorieId">
                    @foreach (var c in _categories)
                    { <option value="@c.Id">@c.Nom</option> }
                </select>
            </div>
            <div class="form-group">
                <label>Type de cuisine *</label>
                <select class="form-select" @bind="_recette.TypeCuisineId">
                    @foreach (var t in _types)
                    { <option value="@t.Id">@t.Nom</option> }
                </select>
            </div>
            <div class="form-group full">
                <label>Description</label>
                <textarea class="form-input" rows="3" @bind="_recette.Description"></textarea>
            </div>
            <div class="form-group full">
                <label>Étapes</label>
                <textarea class="form-input" rows="6" @bind="_recette.Etapes"></textarea>
            </div>
        </div>
        <div class="form-actions">
            <button class="btn btn-primary" @onclick="Sauvegarder">💾 Sauvegarder</button>
        </div>
    </div>

    <!-- Ingrédients -->
    <div class="card">
        <div class="card-header">
            <h2>🥕 Ingrédients</h2>
            <div class="calories-summary">
                <span class="cal-total">🔥 Total : <strong>@_recette.GetCaloriesTotales().ToString("F0") kcal</strong></span>
                <span class="cal-pers">👥 / pers : <strong>@_recette.GetCaloriesParPersonne().ToString("F0") kcal</strong></span>
            </div>
        </div>

        @if (_recette.Ingredients.Any())
        {
            <table class="table">
                <thead>
                    <tr><th>Ingrédient</th><th>Unité</th><th>Quantité</th><th>Calories</th><th></th></tr>
                </thead>
                <tbody>
                    @foreach (var ri in _recette.Ingredients)
                    {
                        <tr>
                            <td>@ri.Ingredient?.Nom</td>
                            <td><span class="badge">@ri.Ingredient?.Unite</span></td>
                            <td>
                                <input class="form-input small" type="number" step="0.1" min="0.1"
                                       value="@ri.Quantite"
                                       @onchange="async e => await MajQuantite(ri.Id, float.Parse(e.Value!.ToString()!))" />
                            </td>
                            <td>@ri.GetCaloriesTotales().ToString("F0") kcal</td>
                            <td><button class="btn btn-sm btn-danger" @onclick="() => Retirer(ri.Id)">✕</button></td>
                        </tr>
                    }
                </tbody>
            </table>
        }
        else { <p class="empty">Aucun ingrédient.</p> }

        <div class="add-ingredient">
            <h3>Ajouter un ingrédient</h3>
            <div class="add-ingredient-form">
                <select class="form-select" @bind="_newIngId">
                    <option value="0">-- Choisir --</option>
                    @foreach (var i in _ingredients)
                    { <option value="@i.Id">@i.Nom (@i.Unite) – @i.CaloriesParUnite kcal/@i.Unite</option> }
                </select>
                <input class="form-input small" type="number" step="0.1" min="0.1"
                       placeholder="Qté" @bind="_newQte" />
                <button class="btn btn-primary" @onclick="Ajouter">+ Ajouter</button>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public int Id { get; set; }

    private Recette?          _recette    = null;
    private List<Categorie>   _categories = new();
    private List<TypeCuisine> _types      = new();
    private List<Ingredient>  _ingredients = new();
    private int   _newIngId = 0;
    private float _newQte   = 1f;
    private string _message = "";
    private bool   _success = false;

    protected override async Task OnInitializedAsync()
    {
        _recette     = await Svc.GetRecetteByIdAsync(Id);
        _categories  = await Svc.GetAllCategoriesAsync();
        _types       = await Svc.GetAllTypesCuisineAsync();
        _ingredients = await Svc.GetAllIngredientsAsync();
    }

    async Task Sauvegarder()
    {
        if (_recette is null) return;
        await Svc.UpdateRecetteAsync(_recette);
        _message = "Recette mise à jour."; _success = true;
    }

    async Task Ajouter()
    {
        if (_newIngId == 0 || _newQte <= 0) return;
        await Svc.AjouterIngredientAsync(_recette!.Id, _newIngId, _newQte);
        _recette = await Svc.GetRecetteByIdAsync(Id);
        _newIngId = 0; _newQte = 1f;
    }

    async Task Retirer(int riId)
    {
        await Svc.RetirerIngredientAsync(riId);
        _recette = await Svc.GetRecetteByIdAsync(Id);
    }

    async Task MajQuantite(int riId, float qte)
    {
        await Svc.MettreAJourQuantiteAsync(riId, qte);
        _recette = await Svc.GetRecetteByIdAsync(Id);
    }
}
