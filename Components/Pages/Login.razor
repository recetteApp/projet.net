@page "/login"
@using RecetteApp.Services
@inject UserCounterService UserSvc
@inject NavigationManager  Nav
@rendermode InteractiveServer

<PageTitle>Connexion – RecetteApp</PageTitle>

<div class="auth-wrapper">
    <div class="auth-card">
        <div class="auth-header">
            <span class="auth-icon">🔐</span>
            <h1>Connexion</h1>
            <p>Accédez à votre espace recettes</p>
        </div>

        @if (!string.IsNullOrEmpty(_message))
        {
            <div class="alert @(_success ? "alert-success" : "alert-danger")">@_message</div>
        }

        <div class="form-group">
            <label>Email</label>
            <input class="form-input" type="email" @bind="_email" placeholder="votre@email.com" />
        </div>
        <div class="form-group">
            <label>Mot de passe</label>
            <input class="form-input" type="password" @bind="_motDePasse" placeholder="••••••••" />
        </div>

        <div class="form-actions">
            <button class="btn btn-primary w-full" @onclick="Connecter">Se connecter</button>
        </div>

        <p class="auth-footer">
            Pas encore de compte ? <a href="/register">S'inscrire</a>
        </p>
    </div>
</div>

@code {
    private string _email      = "";
    private string _motDePasse = "";
    private string _message    = "";
    private bool   _success    = false;

    async Task Connecter()
    {
        if (string.IsNullOrWhiteSpace(_email) || string.IsNullOrWhiteSpace(_motDePasse))
        { _message = "Veuillez remplir tous les champs."; _success = false; return; }

        var user = await UserSvc.ConnecterAsync(_email, _motDePasse);
        if (user is not null)
        {
            _success = true;
            _message = $"Bienvenue, {user.Nom} !";
            Nav.NavigateTo("/");
        }
        else
        {
            _success = false;
            _message = "Email ou mot de passe incorrect.";
        }
    }
}
