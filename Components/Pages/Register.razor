@page "/register"
@using RecetteApp.Services
@inject UserCounterService UserSvc
@inject NavigationManager  Nav
@rendermode InteractiveServer

<PageTitle>Inscription – RecetteApp</PageTitle>

<div class="auth-wrapper">
    <div class="auth-card">
        <div class="auth-header">
            <span class="auth-icon">📝</span>
            <h1>Inscription</h1>
            <p>Créez votre compte RecetteApp</p>
        </div>

        @if (!string.IsNullOrEmpty(_message))
        {
            <div class="alert @(_success ? "alert-success" : "alert-danger")">@_message</div>
        }

        <div class="form-group">
            <label>Nom</label>
            <input class="form-input" @bind="_nom" placeholder="Votre nom" />
        </div>
        <div class="form-group">
            <label>Email</label>
            <input class="form-input" type="email" @bind="_email" placeholder="votre@email.com" />
        </div>
        <div class="form-group">
            <label>Mot de passe</label>
            <input class="form-input" type="password" @bind="_motDePasse" placeholder="Min. 6 caractères" />
        </div>
        <div class="form-group">
            <label>Confirmer le mot de passe</label>
            <input class="form-input" type="password" @bind="_confirm" placeholder="••••••••" />
        </div>

        <div class="form-actions">
            <button class="btn btn-primary w-full" @onclick="Inscrire">Créer le compte</button>
        </div>

        <p class="auth-footer">
            Déjà un compte ? <a href="/login">Se connecter</a>
        </p>
    </div>
</div>

@code {
    private string _nom       = "";
    private string _email     = "";
    private string _motDePasse = "";
    private string _confirm   = "";
    private string _message   = "";
    private bool   _success   = false;

    async Task Inscrire()
    {
        if (string.IsNullOrWhiteSpace(_nom) || string.IsNullOrWhiteSpace(_email) ||
            string.IsNullOrWhiteSpace(_motDePasse))
        { _message = "Tous les champs sont obligatoires."; _success = false; return; }

        if (_motDePasse != _confirm)
        { _message = "Les mots de passe ne correspondent pas."; _success = false; return; }

        if (_motDePasse.Length < 6)
        { _message = "Le mot de passe doit contenir au moins 6 caractères."; _success = false; return; }

        try
        {
            await UserSvc.InscrireAsync(_nom, _email, _motDePasse);
            _success = true;
            _message = "Compte créé avec succès ! Redirection...";
            Nav.NavigateTo("/login");
        }
        catch (InvalidOperationException ex)
        {
            _success = false;
            _message = ex.Message;
        }
    }
}
