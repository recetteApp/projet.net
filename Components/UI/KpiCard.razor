<!-- Components/UI/KpiCard.razor -->
@using Microsoft.AspNetCore.Components
@namespace RecetteApp.Components.UI

<div class="card kpi-card kpi-@Color h-100">
    <div class="card-body">
        <div class="d-flex justify-content-between align-items-center">
            <div>
                <h6 class="card-title mb-0 text-muted">@Label</h6>
                <h3 class="my-2 fw-bold">@Value</h3>
            </div>
            <span style="font-size: 2.5rem; opacity: 0.6;">@Icon</span>
        </div>
    </div>
</div>

@code {
    [Parameter] public string Value { get; set; } = "0";
    [Parameter] public string Label { get; set; } = "";
    [Parameter] public string Icon  { get; set; } = "📊";
    [Parameter] public string Color { get; set; } = "blue";
}